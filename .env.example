# Copy to .env and fill in.  .env is git-ignored.

# Server
PORT=3001
NODE_ENV=development

# Companies House XML Gateway — TEST credentials (sandbox)
# Issued by CH Software Developer Support (ch.softwarehouse@companieshouse.gov.uk)
CH_PRESENTER_ID=66666566000
CH_AUTH_VALUE=DMPRES11127
CH_PACKAGE_REFERENCE=0012
CH_TEST_FLAG=1
CH_GATEWAY_URL=https://xmlgw.companieshouse.gov.uk/v1-0/xmlgw/Gateway

# Flip to "1" while waiting on CH to sort out test credentials / permissions —
# the gateway client will return a fake "accepted" response so the
# Flutter-to-backend contract can still be tested end-to-end.
MOCK_CH_GATEWAY=0

# Companies House Public Data API (read-only: name search, company lookup)
CH_PUBLIC_API_KEY=

# Supabase (shared with mobile app)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
